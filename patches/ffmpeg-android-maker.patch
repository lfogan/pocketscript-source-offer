diff --git a/ffmpeg-android-maker.sh b/ffmpeg-android-maker.sh
index 8f83171..b71ae53 100755
--- a/ffmpeg-android-maker.sh
+++ b/ffmpeg-android-maker.sh
@@ -36,6 +36,18 @@ function prepareOutput() {
   mkdir -p ${OUTPUT_LIB}
   cp ${BUILD_DIR_FFMPEG}/${ANDROID_ABI}/lib/*.so ${OUTPUT_LIB}
 
+  # PocketScript addition: most external libraries (freetype, harfbuzz) build
+  # static-only and produce no .so here. libass and libfribidi are the exception —
+  # both are deliberately built shared (see their build.sh scripts) and never get
+  # copied by the stock script above, which only looks at BUILD_DIR_FFMPEG. Glob
+  # is safe: it silently matches nothing if a component built static-only.
+  shopt -s nullglob
+  EXTERNAL_SO_FILES=(${BUILD_DIR_EXTERNAL}/${ANDROID_ABI}/lib/*.so)
+  if [ ${#EXTERNAL_SO_FILES[@]} -gt 0 ]; then
+    cp ${EXTERNAL_SO_FILES[@]} ${OUTPUT_LIB}
+  fi
+  shopt -u nullglob
+
   OUTPUT_HEADERS=${OUTPUT_DIR}/include/${ANDROID_ABI}
   mkdir -p ${OUTPUT_HEADERS}
   cp -r ${BUILD_DIR_FFMPEG}/${ANDROID_ABI}/include/* ${OUTPUT_HEADERS}
@@ -48,6 +60,14 @@ function checkTextRelocations() {
   TEXT_REL_STATS_FILE=${STATS_DIR}/text-relocations.txt
   ${FAM_READELF} --dynamic ${BUILD_DIR_FFMPEG}/${ANDROID_ABI}/lib/*.so | grep 'TEXTREL\|File' >> ${TEXT_REL_STATS_FILE}
 
+  # PocketScript addition: also check libass.so/libfribidi.so (see prepareOutput).
+  shopt -s nullglob
+  EXTERNAL_SO_FILES=(${BUILD_DIR_EXTERNAL}/${ANDROID_ABI}/lib/*.so)
+  if [ ${#EXTERNAL_SO_FILES[@]} -gt 0 ]; then
+    ${FAM_READELF} --dynamic ${EXTERNAL_SO_FILES[@]} | grep 'TEXTREL\|File' >> ${TEXT_REL_STATS_FILE}
+  fi
+  shopt -u nullglob
+
   if grep -q TEXTREL ${TEXT_REL_STATS_FILE}; then
     echo "There are text relocations in output files:"
     cat ${TEXT_REL_STATS_FILE}
