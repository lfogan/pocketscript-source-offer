diff --git a/scripts/libfribidi/build.sh b/scripts/libfribidi/build.sh
index 0aaf74f..db375bd 100755
--- a/scripts/libfribidi/build.sh
+++ b/scripts/libfribidi/build.sh
@@ -1,11 +1,19 @@
 #!/usr/bin/env bash
 
+# PATCHED from ffmpeg-android-maker's stock libfribidi/build.sh: --enable-shared
+# instead of --enable-static. LGPL compliance requires fribidi to ship as its
+# own dynamically-linked .so, never statically merged into
+# an app-owned binary — unlike libass/freetype/harfbuzz, which are permissively
+# licensed and may merge into one .so. This is the one library in the external-libs
+# set where the framework's stock "everything builds static, only FFmpeg's own
+# build.sh produces .so files" default is wrong for us.
+
 ./configure \
     --prefix=${INSTALL_DIR} \
     --host=${TARGET} \
     --with-sysroot=${SYSROOT_PATH} \
-    --disable-shared \
-    --enable-static \
+    --enable-shared \
+    --disable-static \
     --disable-dependency-tracking \
     --disable-fast-install \
     --disable-debug \
@@ -16,7 +24,7 @@
     RANLIB=${FAM_RANLIB} || exit 1
 
 ${MAKE_EXECUTABLE} clean
-# Compiling only the static library. Just 'make' will build an executable and docs as well.
+# Compiling only the library. Just 'make' will build an executable and docs as well.
 ${MAKE_EXECUTABLE} -j${HOST_NPROC} -C lib
 ${MAKE_EXECUTABLE} install -C lib
 # Installing the .pc file
diff --git a/scripts/libharfbuzz/build.sh b/scripts/libharfbuzz/build.sh
new file mode 100755
index 0000000..86b0677
--- /dev/null
+++ b/scripts/libharfbuzz/build.sh
@@ -0,0 +1,63 @@
+#!/usr/bin/env bash
+
+# Custom external library (harfbuzz switched to Meson-only builds; no autotools
+# support since ~3.0). Built as a static lib to merge into libass.so (see
+# libass/build.sh) — permissively licensed, safe to merge libass/freetype/harfbuzz into one .so.
+
+CROSS_FILE_NAME=crossfile-${ANDROID_ABI}.meson
+
+rm -f ${CROSS_FILE_NAME}
+
+cat > "${CROSS_FILE_NAME}" << EOF
+[binaries]
+c = '${FAM_CC}'
+cpp = '${FAM_CXX}'
+ar = '${FAM_AR}'
+strip = '${FAM_STRIP}'
+pkgconfig = '${PKG_CONFIG_EXECUTABLE}'
+
+[properties]
+needs_exe_wrapper = true
+# Deliberately NOT setting sys_root here: our external-library install prefix
+# (${INSTALL_DIR}) lives outside the NDK sysroot entirely. Meson exports
+# PKG_CONFIG_SYSROOT_DIR from sys_root and pkg-config then prepends it to every
+# path in a .pc file, mangling freetype2's -I path into
+# "<sysroot><install-dir>/include/freetype2" (confirmed empirically: this broke
+# the build with "ft2build.h file not found"). The NDK's target-specific clang
+# wrapper (${FAM_CC}) already bakes in --sysroot itself, so meson doesn't need to.
+
+[host_machine]
+system = 'linux'
+cpu_family = '${CPU_FAMILY}'
+cpu = '${TARGET_TRIPLE_MACHINE_ARCH}'
+endian = 'little'
+
+[built-in options]
+prefix = '${INSTALL_DIR}'
+EOF
+
+BUILD_DIRECTORY=build/${ANDROID_ABI}
+
+rm -rf ${BUILD_DIRECTORY}
+
+${MESON_EXECUTABLE} . ${BUILD_DIRECTORY} \
+  --cross-file ${CROSS_FILE_NAME} \
+  --default-library=static \
+  -Dfreetype=enabled \
+  -Dglib=disabled \
+  -Dgobject=disabled \
+  -Dcairo=disabled \
+  -Dchafa=disabled \
+  -Dpng=disabled \
+  -Dzlib=disabled \
+  -Dicu=disabled \
+  -Dtests=disabled \
+  -Dutilities=disabled \
+  -Ddocs=disabled \
+  -Dintrospection=disabled \
+  -Dbenchmark=disabled || exit 1
+
+cd ${BUILD_DIRECTORY}
+
+${NINJA_EXECUTABLE} -j ${HOST_NPROC}
+${NINJA_EXECUTABLE} install
