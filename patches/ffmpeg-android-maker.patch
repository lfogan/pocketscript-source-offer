diff --git a/scripts/libass/build.sh b/scripts/libass/build.sh
new file mode 100755
index 0000000..6aba931
--- /dev/null
+++ b/scripts/libass/build.sh
@@ -0,0 +1,30 @@
+#!/usr/bin/env bash
+
+# Custom external library (not built into ffmpeg-android-maker's supported-libraries
+# list). Built SHARED and merged with freetype+harfbuzz (both static, ISC/MIT/FTL —
+# permissively licensed, safe to merge). fribidi stays fribidi's own separate .so (LGPL,
+# see libfribidi/build.sh) and is picked up here purely via dynamic linking through
+# pkg-config, never statically absorbed.
+
+./configure \
+    --prefix=${INSTALL_DIR} \
+    --host=${TARGET} \
+    --disable-static \
+    --enable-shared \
+    --with-pic \
+    --disable-fontconfig \
+    --disable-directwrite \
+    --disable-coretext \
+    --disable-libunibreak \
+    --disable-require-system-font-provider \
+    --disable-test \
+    --disable-compare \
+    --disable-profile \
+    --disable-fuzz \
+    CC=${FAM_CC} \
+    AR=${FAM_AR} \
+    RANLIB=${FAM_RANLIB} || exit 1
+
+${MAKE_EXECUTABLE} clean
+${MAKE_EXECUTABLE} -j${HOST_NPROC}
+${MAKE_EXECUTABLE} install
